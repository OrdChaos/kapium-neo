---
import { Icon } from 'astro-icon/components';
import Tooltip from '@/components/ui/tooltip.astro';

const { title, permalink } = Astro.props;

const shareUrl = permalink || Astro.url.href;
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(title);

const shareLinks = [
  {
    name: 'QQ空间',
    icon: 'qzone',
    url: `https://sns.qzone.qq.com/cgi-bin/qzshare/cgi_qzshare_onekey?url=${encodedUrl}&title=${encodedTitle}`,
  },
  {
    name: '微博',
    icon: 'ri:weibo-line',
    url: `https://service.weibo.com/share/share.php?url=${encodedUrl}&title=${encodedTitle}`,
  },
  {
    name: '豆瓣',
    icon: 'ri:douban-line',
    url: `https://www.douban.com/share/service?href=${encodedUrl}&name=${encodedTitle}`,
  },
  {
    name: 'X',
    icon: 'ri:twitter-x-fill',
    url: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`,
  },
  {
    name: 'Facebook',
    icon: 'ri:facebook-fill',
    url: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
  },
  {
    name: 'LinkedIn',
    icon: 'ri:linkedin-box-line',
    url: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
  },
];

const buttonClass =
  'flex h-9 w-9 items-center justify-center rounded-md border border-border/90 bg-background text-foreground transition-all hover:border-primary/50 hover:bg-muted/50 active:scale-95';
---

<div class="flex flex-wrap gap-2">
  {
    shareLinks.map((platform) => (
      <Tooltip label={platform.name}>
        <button
          class={buttonClass}
          onclick={`window.open('${platform.url}', '_blank', 'width=600,height=400')`}
          aria-label={platform.name}
        >
          <Icon name={platform.icon} class="h-5 w-5 scale-90" />
        </button>
      </Tooltip>
    ))
  }

  <Tooltip label="复制链接">
    <button id="copy-link-btn" class={buttonClass} aria-label="复制链接" data-share-url={shareUrl}>
      <Icon name="ri:link" class="h-[18px] w-[18px]" />
    </button>
  </Tooltip>
</div>

<script>
  import { copyToClipboard } from '@/lib/clipboard';

  document.getElementById('copy-link-btn')?.addEventListener('click', (e) => {
    const url = (e.currentTarget as HTMLElement).dataset.shareUrl || window.location.href;
    copyToClipboard(url, '链接已复制');
  });
</script>
