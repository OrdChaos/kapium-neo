---
import { cn } from '@/lib/utils';

interface Props {
  class?: string;
  [key: string]: any;
}

const { class: className, ...rest } = Astro.props;
---

<div
  data-slot="card"
  class={cn(
    'bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-sm w-full overflow-hidden',
    className,
  )}
  {...rest}
>
  <slot />
</div>
