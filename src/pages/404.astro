---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ChevronLeft from '@lucide/astro/icons/chevron-left';
import Search from '@lucide/astro/icons/search';

export const trailingSlash = 'ignore';
---

<BaseLayout title="页面未找到" description="页面未找到">
  <div class="flex min-h-[70vh] flex-col items-center justify-center px-4">
    <div class="w-full max-w-md text-center">
      <div class="mb-8">
        <h1 class="text-primary/20 text-9xl font-bold">404</h1>
        <div class="relative -mt-12 mb-6">
          <h2 class="text-foreground text-3xl font-bold">页面未找到</h2>
        </div>
      </div>

      <p class="text-muted-foreground mb-8">
        抱歉，您访问的页面不存在。可能是链接已过期或输入错误。
      </p>

      <div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
        <a
          href="/"
          class="border-input bg-background hover:bg-accent hover:text-accent-foreground inline-flex w-full items-center justify-center gap-2 rounded-md border px-8 py-3 text-sm font-medium transition-colors sm:w-auto"
        >
          <ChevronLeft class="h-4 w-4" />
          返回首页
        </a>
        <button
          type="button"
          id="search-trigger-404"
          class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex w-full items-center justify-center gap-2 rounded-md px-8 py-3 text-sm font-medium transition-colors sm:w-auto"
        >
          <Search class="h-4 w-4" />
          搜索内容
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.getElementById('search-trigger-404')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-search'));
  });
</script>
