---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Banner from '@/components/Banner.astro';
import Twikoo from '@/components/Twikoo.astro';
import { friendLinks } from '@/config/links';

import ExternalLink from '@lucide/astro/icons/external-link';
import Info from '@lucide/astro/icons/info';
import Users from '@lucide/astro/icons/users';
---

<BaseLayout title="友链" description="朋友们" ogImage="/img/og/links.png">
  <Banner title="友链" subtitle="朋友们" />

  <div class="container mx-auto px-4 py-12">
    <div class="mx-auto max-w-6xl space-y-12">
      <section aria-label="友情链接">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {
            friendLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group border-border bg-card hover:border-primary/50 hover:bg-muted/50 flex items-start gap-4 rounded-lg border p-4 transition-colors"
              >
                <img
                  src={link.avatar}
                  alt={link.name}
                  class="border-border h-14 w-14 shrink-0 rounded-full border-2 object-cover"
                  loading="lazy"
                />
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2">
                    <h3 class="group-hover:text-primary truncate font-semibold transition-colors">
                      {link.name}
                    </h3>
                    <ExternalLink class="text-muted-foreground h-3.5 w-3.5 shrink-0 opacity-0 transition-opacity group-hover:opacity-100" />
                  </div>
                  <p class="text-muted-foreground mt-1 line-clamp-2 text-sm leading-relaxed">
                    {link.description}
                  </p>
                </div>
              </a>
            ))
          }
        </div>

        {
          friendLinks.length === 0 && (
            <div class="border-border bg-muted/30 flex flex-col items-center justify-center rounded-lg border border-dashed py-16 text-center">
              <Users class="text-muted-foreground/50 h-12 w-12" />
              <p class="text-muted-foreground mt-4">暂无友链，欢迎来申请哦～</p>
            </div>
          )
        }
      </section>

      <section>
        <div
          class="border-border bg-card hover:border-primary/50 rounded-xl border p-6 shadow-md transition-all duration-300 hover:shadow-lg"
        >
          <h2 class="mb-4 flex items-center gap-2 text-lg font-semibold">
            <Info class="h-5 w-5" />
            交换友链
          </h2>
          <p class="text-muted-foreground mb-4 text-sm">
            如果你想与我交换友链，欢迎在下方留言联系我。
          </p>

          <h4 class="text-foreground mb-2 font-semibold">要求如下：</h4>
          <ul class="text-muted-foreground mb-4 list-disc space-y-1 pl-5 text-sm">
            <li>非营利性，非资源分享类及盗版传播内容</li>
            <li>SFW，全年龄向</li>
            <li>启用全站 HTTPS</li>
            <li>文章数 &gt;= 10</li>
            <li>已添加本站友链</li>
          </ul>

          <div class="border-border my-4 border-t"></div>

          <h4 class="text-foreground mb-2 font-semibold">本站信息：</h4>
          <ul class="text-muted-foreground list-disc space-y-1 pl-5 text-sm">
            <li>网站名称：谐元场域</li>
            <li>介绍：大抵是序炁的龙窝</li>
            <li>地址：https://www.ordchaos.com</li>
            <li>头像：https://www.ordchaos.com/img/avatar.jpg</li>
          </ul>
        </div>
      </section>

      <section aria-label="评论区域">
        <Twikoo path="/links" />
      </section>
    </div>
  </div>
</BaseLayout>
