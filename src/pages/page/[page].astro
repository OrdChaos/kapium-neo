---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Banner from '@/components/Banner.astro';
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '@/components/ui/card';
import Badge from '@/components/ui/badge.astro';
import { siteConfig } from '@/config/site';
import { estimateReadTime } from '@/lib/utils';

import Calendar from '@lucide/astro/icons/calendar';
import Clock from '@lucide/astro/icons/clock';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const POSTS_PER_PAGE = 21;
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const POSTS_PER_PAGE = 21;
const { page: pageParam } = Astro.params;
const currentPage = Number(pageParam);

const allPosts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const startIdx = (currentPage - 1) * POSTS_PER_PAGE;
const currentPosts = allPosts.slice(startIdx, startIdx + POSTS_PER_PAGE);

function pageHref(p: number) {
  return p === 1 ? '/' : `/page/${p}/`;
}
---

<BaseLayout title={`第 ${currentPage} 页`} description={siteConfig.seo.defaultDescription}>
  <Banner title={siteConfig.title} subtitle={siteConfig.description} height="400px" />
  <div class="container mx-auto px-4 py-12">
    <div class="grid w-full max-w-full gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        currentPosts.map((post) => {
          const readTime = estimateReadTime(post.body || '');
          const href = `/posts/${post.data.abbrlink}/`;
          const catHref = post.data.category
            ? `/categories/${encodeURIComponent(post.data.category)}/`
            : null;
          return (
            <Card class="hover:border-primary/50 flex h-[280px] w-full max-w-full flex-col transition-all duration-300 hover:shadow-lg">
              <CardHeader>
                <div class="mb-2 flex items-center gap-2">
                  {catHref && (
                    <a href={catHref}>
                      <Badge
                        variant="secondary"
                        class="hover:bg-primary hover:text-primary-foreground cursor-pointer transition-colors"
                      >
                        {post.data.category}
                      </Badge>
                    </a>
                  )}
                </div>
                <a href={href}>
                  <CardTitle class="hover:text-primary line-clamp-2 h-[3rem] leading-6 transition-colors">
                    {post.data.title}
                  </CardTitle>
                  <CardDescription class="mt-2 line-clamp-2 h-[3rem] leading-6">
                    {post.data.excerpt || post.data.summary || ''}
                  </CardDescription>
                </a>
              </CardHeader>
              <CardContent class="flex flex-1 flex-col justify-between">
                <div class="text-muted-foreground flex items-center gap-4 text-sm">
                  <div class="flex items-center gap-1">
                    <Calendar class="h-4 w-4" />
                    <span>{post.data.date.toISOString().slice(0, 10)}</span>
                  </div>
                  <div class="flex items-center gap-1">
                    <Clock class="h-4 w-4" />
                    <span>{readTime} 分钟</span>
                  </div>
                </div>
                <div class="relative mt-3">
                  <div class="flex gap-2 overflow-hidden whitespace-nowrap">
                    {post.data.tags?.map((tag: string) => (
                      <a href={`/tags/${encodeURIComponent(tag)}/`}>
                        <Badge
                          variant="outline"
                          class="hover:bg-primary hover:text-primary-foreground shrink-0 cursor-pointer text-xs transition-colors"
                        >
                          {tag}
                        </Badge>
                      </a>
                    ))}
                  </div>
                  <div class="from-card pointer-events-none absolute top-0 right-0 flex h-full w-8 items-center justify-end bg-gradient-to-l to-transparent pr-1 text-xs" />
                </div>
              </CardContent>
            </Card>
          );
        })
      }
    </div>

    {
      totalPages > 1 && (
        <div class="mt-12 flex flex-col items-center">
          <div class="flex items-center gap-2">
            {currentPage > 1 && (
              <a
                href={pageHref(currentPage - 1)}
                class="bg-card hover:border-primary/50 hover:bg-muted/50 border-border cursor-pointer rounded-md border px-4 py-2 transition-colors duration-300"
              >
                上一页
              </a>
            )}

            {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
              <a
                href={pageHref(p)}
                class={`cursor-pointer rounded-md px-4 py-2 ${
                  p === currentPage
                    ? 'bg-primary text-primary-foreground'
                    : 'bg-card hover:border-primary/50 hover:bg-muted/50 border-border border transition-colors duration-300'
                }`}
              >
                {p}
              </a>
            ))}

            {currentPage < totalPages && (
              <a
                href={pageHref(currentPage + 1)}
                class="bg-card hover:border-primary/50 hover:bg-muted/50 border-border cursor-pointer rounded-md border px-4 py-2 transition-colors duration-300"
              >
                下一页
              </a>
            )}
          </div>
          <div class="text-muted-foreground mt-4 text-sm">
            第 {currentPage} 页，共 {totalPages} 页 ({allPosts.length} 篇文章)
          </div>
        </div>
      )
    }
  </div>
</BaseLayout>
