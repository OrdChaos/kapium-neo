---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Banner from '@/components/Banner.astro';
import WifiOff from '@lucide/astro/icons/wifi-off';
import RefreshCw from '@lucide/astro/icons/refresh-cw';
---

<BaseLayout title="离线" description="暂无网络连接">
  <Banner title="离线" subtitle="暂无网络连接" />

  <div class="container mx-auto px-4 py-12">
    <div
      class="mx-auto flex min-h-[50vh] max-w-md flex-col items-center justify-center text-center"
    >
      <div class="mb-8">
        <WifiOff class="text-muted-foreground mx-auto h-24 w-24 opacity-30" />
      </div>

      <h2 class="text-foreground mb-4 text-2xl font-bold">暂无网络连接</h2>

      <p class="text-muted-foreground mb-8 leading-relaxed">
        您当前处于离线状态。请检查网络连接后重试。
      </p>

      <button
        id="retry-btn"
        class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex items-center gap-2 rounded-lg px-6 py-3 text-sm font-medium shadow transition-all duration-300 active:scale-[0.98]"
      >
        <RefreshCw class="h-4 w-4" />
        重新连接
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  document.getElementById('retry-btn')?.addEventListener('click', () => {
    window.location.reload();
  });
</script>
