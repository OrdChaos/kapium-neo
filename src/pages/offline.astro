---
import BaseLayout from '@/layouts/BaseLayout.astro';
import WifiOff from '@lucide/astro/icons/wifi-off';
import RefreshCw from '@lucide/astro/icons/refresh-cw';
---

<BaseLayout title="离线" description="暂无网络连接">
  <div class="flex min-h-[70vh] flex-col items-center justify-center px-4">
    <div class="w-full max-w-md text-center">
      <div class="mb-8">
        <WifiOff class="text-primary/20 mx-auto h-32 w-32" />
      </div>

      <h2 class="text-foreground mb-4 text-3xl font-bold">暂无网络连接</h2>

      <p class="text-muted-foreground mb-8">您当前处于离线状态。请检查网络连接后重试。</p>

      <div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
        <button
          id="retry-btn"
          class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex w-full items-center justify-center gap-2 rounded-md px-8 py-3 text-sm font-medium transition-colors sm:w-auto"
        >
          <RefreshCw class="h-4 w-4" />
          重新连接
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.getElementById('retry-btn')?.addEventListener('click', () => {
    window.location.reload();
  });
</script>
